# Backend environment variables
# Copy to .env and fill in real values locally.

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=coreone
SQLITE_DB=./coreone.db
LANCEDB_PATH=./lancedb_store
UPLOAD_DIR=./uploads
VAULT_PATH=
GRAPHRAG_ROOT=./graphrag
DUANTAOLAO_PATH=

# FPT/OpenAI-compatible API settings
FPT_API=
FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_API_URL=
FPT_MODEL=gemma-4-31B-it
FPT_EMBEDDING_MODEL=multilingual-e5-large
FPT_RERANKER_MODEL=bge-reranker-v2-m3
FPT_EMBEDDING_DIMS=1024
